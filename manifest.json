{
  "manifest_version": 3,
  "name": "Bluesky Text to Audio",
  "version": "0.1.0",
  "description": "Blueskyのタイムライン投稿にplayボタンを表示し、投稿内容をconsole.logに出力する",
  "action": {
    "default_title": "Bluesky Text to Audio（クリックでon/off）"
  },
  "permissions": ["storage", "downloads"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "host_permissions": [
    "http://localhost:50021/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://bsky.app/*"
      ],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
