{
  "manifest_version": 3,
  "name": "Bluesky Text to Audio",
  "version": "0.1.0",
  "description": "Blueskyのタイムライン投稿にplayボタンを表示し、投稿内容をconsole.logに出力する",
  "action": {
    "default_title": "Bluesky Text to Audio（クリックでon/off）"
  },
  "permissions": [
    "storage",
    "downloads"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "host_permissions": [
    "http://localhost:50021/*",
    "http://localhost:62151/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-BrlZ7PJE.js"
      ],
      "matches": [
        "https://bsky.app/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://bsky.app/*"
      ],
      "resources": [
        "assets/tonejs_mml_to_json_bg-Z4r-jVMi.wasm",
        "assets/web-tree-sitter-Bgri87aM.wasm",
        "assets/tree-sitter-mml-5WI6aSUq.wasm",
        "assets/mmlabc_to_smf_wasm_bg-BB-KmDE0.wasm",
        "assets/smf_to_ym2151log_bg-BE_GsBy_.wasm",
        "assets/tree-sitter-mml-DQvQg2JC.wasm",
        "assets/ym2151-Ccu-8unz.wasm",
        "assets/__vite-browser-external-BIHI7g3E.js",
        "assets/content.ts-BYhLAVpF.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
