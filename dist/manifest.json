{
  "manifest_version": 3,
  "name": "Bluesky Text to Audio",
  "version": "0.1.0",
  "description": "Blueskyのタイムライン投稿にplayボタンを表示し、投稿内容をconsole.logに出力する",
  "action": {
    "default_title": "Bluesky Text to Audio（クリックでon/off）"
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "host_permissions": [
    "http://localhost:50021/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-CmpA7coP.js"
      ],
      "matches": [
        "https://bsky.app/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://bsky.app/*"
      ],
      "resources": [
        "assets/tonejs_mml_to_json_bg-Z4r-jVMi.wasm",
        "assets/web-tree-sitter-Bgri87aM.wasm",
        "assets/tree-sitter-mml-5WI6aSUq.wasm",
        "assets/__vite-browser-external-BIHI7g3E.js",
        "assets/content.ts-B-L-xaW_.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
